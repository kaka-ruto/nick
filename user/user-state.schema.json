{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Cafaye User State",
    "type": "object",
    "properties": {
        "core": {
            "type": "object",
            "properties": {
                "tailscale_enabled": {
                    "type": "boolean"
                },
                "zram_enabled": {
                    "type": "boolean"
                },
                "authorized_keys": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "boot": {
                    "type": "object",
                    "properties": {
                        "grub_device": {
                            "type": "string",
                            "description": "Disk device for GRUB bootloader (e.g., /dev/vda, /dev/sda, /dev/nvme0n1)"
                        }
                    }
                },
                "security": {
                    "type": "object",
                    "properties": {
                        "bootstrap_mode": {
                            "type": "boolean",
                            "description": "Temporarily allow direct SSH access during initial setup (disable after Tailscale is confirmed working)"
                        }
                    }
                },
                "auto_shutdown_enabled": {
                    "type": "boolean",
                    "description": "Enable automatic shutdown after period of inactivity to save costs"
                },
                "auto_shutdown_idle_minutes": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1440,
                    "default": 60,
                    "description": "Minutes of inactivity before auto-shutdown (1-1440, default 60)"
                },
                "monitoring": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "check_interval_minutes": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 60
                        },
                        "repeat_alert_minutes": {
                            "type": "integer",
                            "minimum": 5,
                            "maximum": 1440
                        },
                        "thresholds": {
                            "type": "object",
                            "properties": {
                                "ram_percent": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "maximum": 100
                                },
                                "disk_percent": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "maximum": 100
                                },
                                "load_per_core": {
                                    "type": "number",
                                    "minimum": 0.1
                                }
                            }
                        },
                        "processes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "notifier": {
                            "type": "object",
                            "properties": {
                                "provider": {
                                    "enum": [
                                        "none",
                                        "telegram",
                                        "discord",
                                        "slack"
                                    ]
                                },
                                "telegram": {
                                    "type": "object",
                                    "properties": {
                                        "bot_token": {
                                            "type": "string"
                                        },
                                        "chat_id": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "discord": {
                                    "type": "object",
                                    "properties": {
                                        "webhook_url": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "slack": {
                                    "type": "object",
                                    "properties": {
                                        "webhook_url": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "interface": {
            "type": "object",
            "properties": {
                "terminal": {
                    "type": "object",
                    "properties": {
                        "shell": {
                            "enum": [
                                "zsh",
                                "bash"
                            ]
                        },
                        "multiplexer": {
                            "enum": [
                                "zellij",
                                "tmux",
                                "none"
                            ]
                        }
                    }
                },
                "theme": {
                    "type": "string"
                }
            }
        },
        "languages": {
            "type": "object",
            "additionalProperties": {
                "type": "boolean"
            }
        },
        "services": {
            "type": "object",
            "properties": {
                "postgresql": {
                    "type": "boolean"
                },
                "redis": {
                    "type": "boolean"
                }
            }
        },
        "frameworks": {
            "type": "object",
            "properties": {
                "rails": {
                    "type": "boolean"
                },
                "django": {
                    "type": "boolean"
                },
                "nextjs": {
                    "type": "boolean"
                }
            }
        },
        "editors": {
            "type": "object",
            "properties": {
                "neovim": {
                    "type": "boolean"
                },
                "helix": {
                    "type": "boolean"
                },
                "vscode_server": {
                    "type": "boolean"
                },
                "default": {
                    "enum": [
                        "neovim",
                        "helix",
                        "vscode_server",
                        "none"
                    ]
                },
                "distributions": {
                    "type": "object",
                    "properties": {
                        "nvim": {
                            "type": "object",
                            "properties": {
                                "lazyvim": {
                                    "type": "boolean"
                                },
                                "astronvim": {
                                    "type": "boolean"
                                },
                                "nvchad": {
                                    "type": "boolean"
                                },
                                "lunarvim": {
                                    "type": "boolean"
                                }
                            }
                        }
                    }
                }
            }
        },
        "dev_tools": {
            "type": "object",
            "additionalProperties": {
                "type": "boolean"
            }
        }
    }
}
