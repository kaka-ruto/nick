<% content_for(:title) { "Library | Chapterwan" } %>
<% @layout_class = "cw-main-wide min-h-screen text-[color:var(--cw-ink)]" %>

<% content_for :header do %>
  <header class="cw-topbar sticky top-0 z-20">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4 md:px-10">
      <div class="inline-flex items-center gap-3">
        <%= image_tag "chapterwan-icon.svg", aria: { hidden: true }, size: 20, class: "h-5 w-5" %>
        <span class="cw-brand text-sm uppercase tracking-[0.2em]">Library</span>
      </div>
      <nav class="flex items-center gap-2">
        <%= link_to "Homepage", root_path, class: "cw-link" %>
        <% if signed_in? %>
          <%= link_to "Home", home_path, class: "cw-link cw-link-primary" %>
        <% else %>
          <%= link_to "Sign in", new_session_path, class: "cw-link cw-link-primary" %>
        <% end %>
      </nav>
    </div>
  </header>
<% end %>

<section class="mx-auto w-full max-w-7xl px-6 pb-16 pt-10 md:px-10">
  <div class="mb-8 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="cw-kicker">Public Reading Collection</p>
      <h1 class="mt-2 text-5xl font-semibold leading-[0.95]">Browse Published Books</h1>
      <p class="cw-subhead mt-3">Search by title, author, tags, and category. This is the complete public discovery surface.</p>
    </div>
    <div class="cw-panel px-4 py-3 text-sm">
      <span class="font-semibold"><%= @books.size %></span> result<%= "s" unless @books.size == 1 %>
    </div>
  </div>

  <%= form_with url: library_path, method: :get, local: true, class: "cw-panel mb-8 grid gap-3 p-4 md:grid-cols-[1.5fr_1fr_auto]" do |form| %>
    <%= form.search_field :q, value: params[:q], placeholder: "Search title, author, or tag", class: "cw-input" %>
    <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), { include_blank: "All categories" }, { class: "cw-input" } %>
    <%= form.submit "Search", class: "cw-link cw-link-primary h-fit self-center" %>
  <% end %>

  <% if @featured_book.present? %>
    <article class="cw-panel mb-8 grid gap-5 p-6 md:grid-cols-[1.2fr_auto] md:items-center">
      <div>
        <p class="cw-kicker">Featured Book</p>
        <div class="relative mt-4 w-44 overflow-hidden rounded-2xl shadow-[var(--cw-shadow)]">
          <%= image_tag(book_cover_image(@featured_book), alt: "Cover for #{@featured_book.title}", class: "block aspect-[3/4] w-full object-cover") %>
          <div class="absolute inset-x-0 top-0 p-3">
            <h2 class="font-[var(--cw-serif)] text-base font-semibold leading-tight text-[#f5f5f0] [text-shadow:0_1px_0_rgba(0,0,0,0.45),0_2px_8px_rgba(0,0,0,0.45)]"><%= @featured_book.title %></h2>
            <% if @featured_book.subtitle.present? %>
              <p class="mt-1 text-[11px] leading-snug text-[#f5f5f0]/95 [text-shadow:0_1px_4px_rgba(0,0,0,0.45)]"><%= @featured_book.subtitle %></p>
            <% end %>
            <p class="mt-2 text-[10px] font-semibold uppercase tracking-[0.14em] text-[#f5f5f0]/90 [text-shadow:0_1px_4px_rgba(0,0,0,0.45)]"><%= @featured_book.author %></p>
          </div>
        </div>
      </div>
      <%= link_to "Read", book_slug_path(@featured_book), class: "cw-read-btn w-fit" %>
    </article>
  <% end %>

  <div class="grid gap-4 md:grid-cols-3">
    <% @books.each do |book| %>
      <article class="cw-panel p-5">
        <div class="relative overflow-hidden rounded-2xl shadow-[var(--cw-shadow)]">
          <%= image_tag(book_cover_image(book), alt: "Cover for #{book.title}", class: "block aspect-[3/4] w-full object-cover") %>
          <div class="absolute inset-x-0 top-0 p-4">
            <h3 class="font-[var(--cw-serif)] text-lg font-semibold leading-tight text-[#f5f5f0] [text-shadow:0_1px_0_rgba(0,0,0,0.45),0_2px_8px_rgba(0,0,0,0.45)]"><%= book.title %></h3>
            <% if book.subtitle.present? %>
              <p class="mt-1 text-xs leading-snug text-[#f5f5f0]/95 [text-shadow:0_1px_4px_rgba(0,0,0,0.45)]"><%= book.subtitle %></p>
            <% end %>
            <p class="mt-2 text-[10px] font-semibold uppercase tracking-[0.14em] text-[#f5f5f0]/90 [text-shadow:0_1px_4px_rgba(0,0,0,0.45)]"><%= book.author %></p>
          </div>
        </div>
        <% if book.tags.any? %>
          <p class="mt-3 text-xs text-[color:var(--cw-muted)]"><%= book.tag_names.join(" · ") %></p>
        <% end %>
        <div class="mt-4 flex items-center justify-between">
          <p class="cw-kicker"><%= book.category.name %></p>
          <%= link_to "Read", book_slug_path(book), class: "cw-read-btn" %>
        </div>
      </article>
    <% end %>
  </div>
</section>
