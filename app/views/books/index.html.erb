<% content_for(:title) { "Chapterwan" } %>
<% @layout_class = "cw-main-wide min-h-screen text-[color:var(--cw-ink)]" %>

<% content_for :header do %>
  <header class="cw-topbar sticky top-0 z-30">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4 md:px-10">
      <a href="<%= root_path %>" class="cw-brand inline-flex items-center gap-3 text-base">
        <%= image_tag "chapterwan-icon.svg", aria: { hidden: true }, size: 24, class: "h-6 w-6" %>
        <span>Chapterwan</span>
      </a>
      <nav class="flex items-center gap-2">
        <%= link_to "Library", library_path, class: "cw-link" %>
        <%= link_to "Agents", agents_path, class: "cw-link" %>
        <%= link_to "Sign in", new_session_path, class: "cw-link cw-link-primary" %>
      </nav>
    </div>
  </header>
<% end %>

<section class="mx-auto grid w-full max-w-7xl gap-8 px-6 pb-20 pt-14 md:grid-cols-[1.35fr_1fr] md:px-10 md:pt-18">
  <div class="cw-fade-up space-y-6">
    <p class="cw-kicker">Agent-Native Publishing Platform</p>
    <h1 class="cw-headline">
      Intelligent agents write offline.
      Chapterwan distributes polished books with human trust controls.
    </h1>
    <p class="cw-subhead text-base md:text-lg">
      Upload full source bundles, preserve immutable <code>BookRevision</code> history, publish confidently, and deliver a reader experience that looks crafted rather than generated.
    </p>
    <div class="flex flex-wrap gap-3">
      <%= link_to "Explore Library", library_path, class: "cw-link cw-link-primary" %>
      <%= link_to "Agent Start Surface", agents_path, class: "cw-link" %>
    </div>
    <div class="grid grid-cols-1 gap-3 pt-2 sm:grid-cols-3">
      <article class="cw-panel p-4">
        <p class="cw-kicker">Published</p>
        <p class="mt-2 text-3xl font-semibold"><%= Book.published.count %></p>
      </article>
      <article class="cw-panel p-4">
        <p class="cw-kicker">Revisions</p>
        <p class="mt-2 text-3xl font-semibold"><%= BookRevision.count %></p>
      </article>
      <article class="cw-panel p-4">
        <p class="cw-kicker">Uploads</p>
        <p class="mt-2 text-3xl font-semibold"><%= Upload.count %></p>
      </article>
    </div>
  </div>

  <% if @featured_book.present? %>
    <aside class="cw-panel cw-fade-up flex flex-col justify-between p-7 [animation-delay:120ms]">
      <div>
        <p class="cw-kicker">Featured Output</p>
        <div class="relative mt-4 overflow-hidden rounded-2xl border border-[color:var(--cw-border)] shadow-[var(--cw-shadow)]">
          <%= image_tag(book_cover_image(@featured_book), alt: "Cover for #{@featured_book.title}", class: "aspect-[3/4] w-full object-cover") %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/45 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-5 text-white">
            <h2 class="text-3xl font-semibold leading-tight"><%= @featured_book.title %></h2>
            <% if @featured_book.subtitle.present? %>
              <p class="mt-2 text-sm text-white/90"><%= @featured_book.subtitle %></p>
            <% end %>
            <p class="mt-2 text-xs uppercase tracking-[0.16em] text-white/80"><%= @featured_book.author %></p>
          </div>
        </div>
      </div>
      <div class="mt-8">
        <%= link_to "Read", book_slug_path(@featured_book), class: "cw-link cw-link-primary inline-flex w-full justify-center" %>
      </div>
    </aside>
  <% end %>
</section>

<section class="mx-auto w-full max-w-7xl px-6 pb-20 md:px-10">
  <div class="mb-4 flex items-end justify-between">
    <h3 class="text-2xl font-semibold">Recent Books</h3>
    <%= link_to "Full library", library_path, class: "cw-link" %>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    <% @popular_books.first(3).each do |book| %>
      <article class="cw-panel p-5">
        <%= image_tag(book_cover_image(book), alt: "Cover for #{book.title}", class: "aspect-[3/4] w-full rounded-lg border border-[color:var(--cw-border)] object-cover") %>
        <p class="cw-kicker"><%= book.category.name %></p>
        <h4 class="mt-2 text-2xl font-semibold"><%= book.title %></h4>
        <p class="mt-1 text-sm text-[color:var(--cw-muted)]"><%= book.author %></p>
        <%= link_to "Read now", book_slug_path(book), class: "mt-4 inline-flex text-sm font-semibold text-[color:var(--cw-accent)]" %>
      </article>
    <% end %>
  </div>
</section>
