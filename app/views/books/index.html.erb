<% content_for(:title) { "Library | Chapterwan" } %>
<% @layout_class = "books landing" %>

<% content_for :header do %>
  <nav class="lp-header">
    <a href="<%= root_path %>" class="product__wordmark btn btn--plain txt-large center">
      <%= image_tag "chapterwan-icon.svg", aria: { hidden: true }, size: 24 %>
      <span>Chapterwan</span>
    </a>

    <div class="flex gap-half align-center">
      <% if Current.user %>
        <%= link_to "Dashboard", users_path, class: "btn btn--plain" %>
      <% else %>
        <%= link_to "Sign in", new_session_path, class: "btn" %>
      <% end %>
    </div>
  </nav>
<% end %>

<section class="lp-hero">
  <p class="lp-kicker">Public Library</p>
  <h1>Browse published books and discover what readers are opening now.</h1>

  <%= form_with url: root_path, method: :get, local: true, class: "lp-search" do |form| %>
    <%= form.search_field :q, value: params[:q], placeholder: "Search books, authors, or tags", class: "input" %>
    <%= form.select :category_id, options_from_collection_for_select(@categories, :id, :name, params[:category_id]), { include_blank: "All categories" }, { class: "input" } %>
    <%= form.submit "Search", class: "btn btn--reversed" %>
  <% end %>

  <% if @featured_book.present? %>
    <article class="lp-featured theme--<%= @featured_book.theme %>">
      <p>Featured</p>
      <h2><%= @featured_book.title %></h2>
      <p><%= @featured_book.subtitle.presence || @featured_book.author.presence || @featured_book.category.name %></p>
      <%= link_to "Read now", book_slug_path(@featured_book), class: "btn btn--plain" %>
    </article>
  <% end %>
</section>

<% if @popular_books.any? %>
  <section class="lp-section">
    <div class="lp-section__header">
      <h3>Most Read</h3>
      <small>Based on recent unique readers</small>
    </div>
    <div class="library lp-grid">
      <%= render @popular_books %>
    </div>
  </section>
<% end %>

<section class="lp-section">
  <div class="lp-section__header">
    <h3><%= params[:q].present? ? "Search Results" : "Library" %></h3>
    <small><%= pluralize(@books.size, "book") %></small>
  </div>

  <div class="library lp-grid">
    <%= render @books %>
    <%= render "books/new" if signed_in? %>
  </div>
</section>
