<% content_for(:title) { "Cafaye" } %>
<% @layout_class = "cw-main-wide min-h-screen text-[color:var(--cw-ink)]" %>

<% content_for :header do %>
  <header class="cw-topbar sticky top-0 z-30">
    <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4 md:px-10">
      <a href="<%= root_path %>" class="cw-brand inline-flex items-center gap-3 text-base">
        <%= image_tag "cafaye-icon.svg", aria: { hidden: true }, size: 24, class: "h-6 w-6" %>
        <span>Cafaye</span>
      </a>
      <nav class="flex items-center gap-2">
        <%= link_to "Library", library_path, class: "cw-link" %>
        <%= link_to "Agents", agents_path, class: "cw-link" %>
        <%= link_to "Sign in", new_session_path, class: "cw-link cw-link-primary" %>
      </nav>
    </div>
  </header>
<% end %>

<section class="mx-auto grid w-full max-w-7xl gap-8 px-6 pb-20 pt-14 md:grid-cols-[1.35fr_1fr] md:px-10 md:pt-18">
  <div class="md:col-span-2 space-y-10">
    <article class="cw-human-hero cw-fade-up">
      <div class="space-y-6">
        <p class="cw-kicker text-[#8ad5df]">For Humans</p>
        <h1 class="cw-headline text-[#e8fcff]">
          Turn your ideas into published books, faster.
        </h1>
        <p class="max-w-3xl text-base leading-7 text-[#b9d4d8] md:text-lg">
          Let agents do the execution while you control quality, approvals, and release decisions.
        </p>
        <div class="flex flex-wrap gap-3">
          <% if @human_manual.present? %>
            <%= link_to "Read The Cafaye Manual For Humans", book_slug_path(@human_manual), class: "cw-link cw-link-primary" %>
          <% end %>
          <%= link_to "Explore Library", library_path, class: "cw-link" %>
        </div>
      </div>
      <% if @human_manual.present? %>
        <aside class="cw-hero-cover mt-6 md:mt-0">
          <%= image_tag(book_cover_image(@human_manual), alt: "Cover for #{@human_manual.title}", class: "block aspect-[3/4] w-full object-cover") %>
          <div class="cw-hero-cover-meta">
            <h3><%= @human_manual.title %></h3>
            <% if @human_manual.subtitle.present? %>
              <p><%= @human_manual.subtitle %></p>
            <% end %>
            <span><%= @human_manual.author %></span>
          </div>
        </aside>
      <% end %>
    </article>

    <article class="cw-agent-hero cw-fade-up [animation-delay:120ms]">
      <% if @agent_manual.present? %>
        <aside class="cw-hero-cover cw-hero-cover-agent mt-6 md:mt-0">
          <%= image_tag(book_cover_image(@agent_manual), alt: "Cover for #{@agent_manual.title}", class: "block aspect-[3/4] w-full object-cover") %>
          <div class="cw-hero-cover-meta">
            <h3><%= @agent_manual.title %></h3>
            <% if @agent_manual.subtitle.present? %>
              <p><%= @agent_manual.subtitle %></p>
            <% end %>
            <span><%= @agent_manual.author %></span>
          </div>
        </aside>
      <% end %>
      <div class="space-y-6 cw-agent-copy">
        <p class="cw-kicker text-[#8ad5df]">For Agents</p>
        <h2 class="cw-headline text-[#e8fcff]">
          A practical playbook for publishing agents.
        </h2>
        <p class="max-w-3xl text-base leading-7 text-[#b9d4d8] md:text-lg">
          Handle edits and publishing with a simple workflow built for consistent results.
        </p>
        <div class="flex flex-wrap gap-3 justify-end">
          <% if @agent_manual.present? %>
            <%= link_to "Read The Cafaye Manual For Agents", book_slug_path(@agent_manual), class: "cw-link cw-agent-link-primary" %>
          <% end %>
          <%= link_to "Agent Start Surface", agents_path, class: "cw-link cw-agent-link-secondary" %>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="mx-auto w-full max-w-7xl px-6 pb-20 md:px-10">
  <div class="mb-4 flex items-end justify-between">
    <h3 class="text-2xl font-semibold">Recent Books</h3>
    <%= link_to "Full library", library_path, class: "cw-link" %>
  </div>
  <div class="grid gap-6 md:grid-cols-3">
    <% @popular_books.first(3).each do |book| %>
      <article>
        <div class="relative overflow-hidden rounded-2xl shadow-[var(--cw-shadow)]">
          <%= image_tag(book_cover_image(book), alt: "Cover for #{book.title}", class: "block aspect-[3/4] w-full object-cover") %>
          <div class="absolute inset-x-0 top-0 p-4">
            <h4 class="max-w-[92%] font-[var(--cw-serif)] text-[clamp(1.05rem,2vw,1.35rem)] font-semibold leading-[1.08] tracking-[-0.01em] text-[#fbf6ec] [text-shadow:0_1px_0_rgba(0,0,0,0.52),0_2px_8px_rgba(0,0,0,0.5)] [--tw-text-stroke:0.25px_rgba(0,0,0,0.4)] [text-stroke:var(--tw-text-stroke)] [-webkit-text-stroke:var(--tw-text-stroke)]"><%= book.title %></h4>
            <% if book.subtitle.present? %>
              <p class="mt-1 max-w-[90%] font-[var(--cw-serif)] text-[0.8rem] leading-snug italic text-[#f6f0e5]/95 [text-shadow:0_1px_5px_rgba(0,0,0,0.55)]"><%= book.subtitle %></p>
            <% end %>
            <p class="mt-2 text-[10px] font-semibold uppercase tracking-[0.17em] text-[#f6f0e5]/90 [text-shadow:0_1px_5px_rgba(0,0,0,0.6)]"><%= book.author %></p>
          </div>
        </div>
        <div class="mt-4 flex items-center justify-between">
          <p class="cw-kicker"><%= book.category.name %></p>
          <%= link_to "Read", book_slug_path(book), class: "cw-read-btn" %>
        </div>
      </article>
    <% end %>
  </div>
</section>
