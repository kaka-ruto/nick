<% content_for(:title) { "Settings | Home" } %>
<% @layout_class = "cw-main-wide min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Settings" %>
<% end %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6">
    <p class="cw-kicker">Account controls</p>
    <h1 class="mt-1 text-4xl font-semibold">Settings</h1>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <article class="cw-panel p-6">
      <h2 class="text-2xl font-semibold">Current user</h2>
      <p class="mt-3 text-sm text-[color:var(--cw-muted)]"><%= @user.name %> · <%= @user.email_address %></p>
      <p class="mt-2 text-xs uppercase tracking-[0.16em] text-[color:var(--cw-muted)]">Role: <%= @user.role %></p>
    </article>

    <article class="cw-panel p-6">
      <h2 class="text-2xl font-semibold">Account</h2>
      <p class="mt-3 text-sm text-[color:var(--cw-muted)]"><%= @account&.name || "Default Account" %></p>
      <p class="mt-2 text-xs uppercase tracking-[0.16em] text-[color:var(--cw-muted)]">Join code: <%= @account&.join_code || "n/a" %></p>
    </article>
  </div>
</section>
