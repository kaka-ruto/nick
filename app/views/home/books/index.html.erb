<% content_for(:title) { "Books | Home" } %>
<% @layout_class = "min-h-screen bg-slate-100 text-slate-900" %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6 flex items-end justify-between">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Human workspace</p>
      <h1 class="mt-1 text-3xl font-semibold">Books</h1>
    </div>
    <%= link_to "Back to home", home_path, class: "rounded-full border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:border-slate-400" %>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <% @books.each do |book| %>
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-xs uppercase tracking-[0.16em] text-slate-500"><%= book.category.name %></p>
        <h2 class="mt-2 text-xl font-semibold"><%= book.title %></h2>
        <p class="text-sm text-slate-600"><%= book.author %></p>
        <p class="mt-3 text-xs text-slate-500">Draft #<%= book.current_draft_revision&.number || "n/a" %> · Published #<%= book.published_revision&.number || "none" %></p>
        <%= link_to "Open details", home_book_path(book), class: "mt-4 inline-flex text-sm font-medium text-cyan-700" %>
      </article>
    <% end %>
  </div>
</section>
