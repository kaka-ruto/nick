<% content_for(:title) { "Books | Home" } %>
<% @layout_class = "min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Books" %>
<% end %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6">
    <p class="cw-kicker">Human workspace</p>
    <h1 class="mt-1 text-4xl font-semibold">Books</h1>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <% @books.each do |book| %>
      <article class="cw-panel p-5">
        <p class="cw-kicker"><%= book.category.name %></p>
        <h2 class="mt-2 text-xl font-semibold"><%= book.title %></h2>
        <p class="text-sm text-[color:var(--cw-muted)]"><%= book.author %></p>
        <p class="mt-3 text-xs text-[color:var(--cw-muted)]">Draft #<%= book.current_draft_revision&.number || "n/a" %> · Published #<%= book.published_revision&.number || "none" %></p>
        <%= link_to "Open details", home_book_path(book), class: "mt-4 inline-flex text-sm font-medium text-[color:var(--cw-accent)]" %>
      </article>
    <% end %>
  </div>
</section>
