<% content_for(:title) { "#{@book.title} | Home Books" } %>
<% @layout_class = "min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Book Detail" %>
<% end %>

<section class="mx-auto w-full max-w-7xl space-y-6 px-6 py-10 md:px-10">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="cw-kicker"><%= @book.category.name %></p>
      <h1 class="mt-2 text-3xl font-semibold"><%= @book.title %></h1>
      <p class="mt-1 text-[color:var(--cw-muted)]"><%= @book.author %></p>
    </div>
    <%= link_to "Back to books", home_books_path, class: "cw-link" %>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <article class="cw-panel p-5">
      <h2 class="text-lg font-semibold">Revision state</h2>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-[color:var(--cw-muted)]">Current draft</dt>
          <dd class="font-medium"><%= @book.current_draft_revision&.number || "n/a" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-[color:var(--cw-muted)]">Published revision</dt>
          <dd class="font-medium"><%= @book.published_revision&.number || "none" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-[color:var(--cw-muted)]">Published flag</dt>
          <dd class="font-medium"><%= @book.published? ? "yes" : "no" %></dd>
        </div>
      </dl>
    </article>

    <article class="cw-panel p-5">
      <h2 class="text-lg font-semibold">Commerce</h2>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-[color:var(--cw-muted)]">Pricing type</dt>
          <dd class="font-medium"><%= @book.pricing_type %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-[color:var(--cw-muted)]">Price cents</dt>
          <dd class="font-medium"><%= @book.price_cents || 0 %></dd>
        </div>
      </dl>
    </article>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <article class="cw-panel p-5">
      <h2 class="text-lg font-semibold">Recent revisions</h2>
      <div class="mt-4 space-y-2">
        <% @revisions.each do |revision| %>
          <div class="cw-panel-soft px-3 py-2 text-sm">
            Revision #<%= revision.number %> · upload #<%= revision.upload_id %> · <%= revision.created_at.to_fs(:short) %>
          </div>
        <% end %>
      </div>
    </article>
    <article class="cw-panel p-5">
      <h2 class="text-lg font-semibold">Recent uploads</h2>
      <div class="mt-4 space-y-2">
        <% @uploads.each do |upload| %>
          <div class="cw-panel-soft px-3 py-2 text-sm">
            Upload #<%= upload.id %> · <%= upload.status %> · <%= upload.created_at.to_fs(:short) %>
          </div>
        <% end %>
      </div>
    </article>
  </div>
</section>
