<% content_for(:title) { "Publishing | Home" } %>
<% @layout_class = "cw-main-wide min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Publishing" %>
<% end %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6">
    <p class="cw-kicker">Release controls</p>
    <h1 class="mt-1 text-4xl font-semibold">Publishing</h1>
  </div>

  <article class="cw-panel p-6">
    <h2 class="text-2xl font-semibold">Publication state by book</h2>
    <div class="mt-4 space-y-2">
      <% @books.each do |book| %>
        <div class="cw-panel-soft px-3 py-2 text-sm">
          <span class="font-medium"><%= book.title %></span>
          <span class="text-[color:var(--cw-muted)]">
            · draft #<%= book.current_draft_revision&.number || "n/a" %>
            · published #<%= book.published_revision&.number || "none" %>
            · live: <%= book.published? ? "yes" : "no" %>
          </span>
        </div>
      <% end %>
    </div>
  </article>
</section>
