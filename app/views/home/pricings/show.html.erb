<% content_for(:title) { "Pricing | Home" } %>
<% @layout_class = "min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Pricing" %>
<% end %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6">
    <p class="cw-kicker">Commercial controls</p>
    <h1 class="mt-1 text-4xl font-semibold">Pricing</h1>
  </div>

  <article class="cw-panel p-6">
    <h2 class="text-2xl font-semibold">Book pricing inventory</h2>
    <div class="mt-4 space-y-2">
      <% @books.each do |book| %>
        <div class="cw-panel-soft px-3 py-2 text-sm">
          <span class="font-medium"><%= book.title %></span>
          <span class="text-[color:var(--cw-muted)]">· <%= book.pricing_type %> · <%= book.price_cents || 0 %> cents</span>
        </div>
      <% end %>
    </div>
  </article>
</section>
