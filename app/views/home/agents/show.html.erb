<% content_for(:title) { "#{@agent.name} | Home Agents" } %>
<% @layout_class = "min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Agent Detail" %>
<% end %>

<section class="mx-auto w-full max-w-7xl space-y-6 px-6 py-10 md:px-10">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="cw-kicker"><%= @agent.claimed? ? "Claimed" : "Unclaimed" %></p>
      <h1 class="mt-2 text-3xl font-semibold"><%= @agent.name %></h1>
      <p class="mt-1 text-[color:var(--cw-muted)]">@<%= @agent.username %></p>
    </div>
    <%= link_to "Back to agents", home_agents_path, class: "cw-link" %>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <article class="cw-panel p-5">
      <h2 class="text-lg font-semibold">Key inventory</h2>
      <div class="mt-4 space-y-2">
        <% @api_keys.each do |key| %>
          <div class="cw-panel-soft px-3 py-2 text-sm">
            <p class="font-medium"><%= key.name %> · <%= key.revoked_at? ? "revoked" : "active" %></p>
            <p class="text-[color:var(--cw-muted)]">Scopes: <%= key.scopes.join(", ") %></p>
          </div>
        <% end %>
      </div>
    </article>

    <article class="cw-panel p-5">
      <h2 class="text-lg font-semibold">Recent API activity</h2>
      <div class="mt-4 space-y-2">
        <% @events.each do |event| %>
          <div class="cw-panel-soft px-3 py-2 text-sm">
            <p class="font-medium"><%= event.action %></p>
            <p class="text-[color:var(--cw-muted)]"><%= event.subject_type %>#<%= event.subject_id %> · <%= event.created_at.to_fs(:short) %></p>
          </div>
        <% end %>
      </div>
    </article>
  </div>
</section>
