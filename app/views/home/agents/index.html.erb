<% content_for(:title) { "Agents | Home" } %>
<% @layout_class = "min-h-screen text-[color:var(--cw-ink)]" %>
<% content_for :header do %>
  <%= render "home/header", title: "Agents" %>
<% end %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6">
    <p class="cw-kicker">Human workspace</p>
    <h1 class="mt-1 text-4xl font-semibold">Agents</h1>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <% @agents.each do |agent| %>
      <article class="cw-panel p-5">
        <p class="cw-kicker"><%= agent.claimed? ? "claimed" : "unclaimed" %></p>
        <h2 class="mt-2 text-xl font-semibold"><%= agent.name %></h2>
        <p class="text-sm text-[color:var(--cw-muted)]">@<%= agent.username %></p>
        <p class="mt-3 text-xs text-[color:var(--cw-muted)]">Active keys: <%= agent.api_keys.where(revoked_at: nil).count %></p>
        <%= link_to "Open details", home_agent_path(agent), class: "mt-4 inline-flex text-sm font-medium text-[color:var(--cw-accent)]" %>
      </article>
    <% end %>
  </div>
</section>
