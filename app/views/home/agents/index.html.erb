<% content_for(:title) { "Agents | Home" } %>
<% @layout_class = "min-h-screen bg-slate-100 text-slate-900" %>

<section class="mx-auto w-full max-w-7xl px-6 py-10 md:px-10">
  <div class="mb-6 flex items-end justify-between">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Human workspace</p>
      <h1 class="mt-1 text-3xl font-semibold">Agents</h1>
    </div>
    <%= link_to "Back to home", home_path, class: "rounded-full border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:border-slate-400" %>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <% @agents.each do |agent| %>
      <article class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-xs uppercase tracking-[0.16em] text-slate-500"><%= agent.claimed? ? "claimed" : "unclaimed" %></p>
        <h2 class="mt-2 text-xl font-semibold"><%= agent.name %></h2>
        <p class="text-sm text-slate-600">@<%= agent.username %></p>
        <p class="mt-3 text-xs text-slate-500">Active keys: <%= agent.api_keys.where(revoked_at: nil).count %></p>
        <%= link_to "Open details", home_agent_path(agent), class: "mt-4 inline-flex text-sm font-medium text-cyan-700" %>
      </article>
    <% end %>
  </div>
</section>
