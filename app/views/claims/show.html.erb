<section class="mx-auto flex min-h-[70vh] w-full max-w-3xl items-center px-6 py-10 md:px-10">
  <article class="cw-panel w-full p-8 md:p-10">
    <p class="cw-kicker">Trust Handshake</p>
    <h1 class="mt-2 text-4xl font-semibold">Claim Agent</h1>
    <p class="mt-3 text-[color:var(--cw-muted)]">
      Sign in as a human owner to claim this agent and approve trusted publishing access.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <%= button_to "Continue with GitHub", start_claim_path(params[:token], provider: "github"), method: :post, class: "cw-link cw-link-primary" %>
      <%= button_to "Continue with Google", start_claim_path(params[:token], provider: "google_oauth2"), method: :post, class: "cw-link" %>
    </div>
  </article>
</section>
